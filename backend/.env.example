# Copy to .env (or set as real environment variables) — never commit actual secrets.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=helping_hands
DB_USERNAME=helping_hands_user
DB_PASSWORD=changeme

JWT_SECRET=replace-this-with-a-long-random-secret-min-32-chars
JWT_EXPIRATION_MS=86400000

JPA_DDL_AUTO=validate

STORAGE_BASE_PATH=./uploads

# 256-bit AES key, base64-encoded, used to encrypt every uploaded document
# at rest. Generate with: openssl rand -base64 32
STORAGE_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-base64-32

# Used only by POST /api/v1/auth/register-admin to provision Administrator
# accounts without a manual SQL trick. Generate with: openssl rand -base64 32
ADMIN_BOOTSTRAP_SECRET=replace-with-a-long-random-secret

# Which email backend is active: "resend" (default), "sendgrid", or "smtp".
# Both resend and sendgrid use an HTTPS API — the only reliable option on
# Render/most PaaS hosts, since they block outbound SMTP ports (25/465/587)
# at the network level regardless of credentials. Use "smtp" only for the
# docker-compose/VPS self-hosting path.
EMAIL_PROVIDER=resend

# Resend (https://resend.com) — free tier, HTTPS API, no blocked-port issues.
# IMPORTANT: onboarding@resend.dev only delivers to the email address that
# owns your Resend account — every other recipient gets a 403 until you
# verify a real domain at resend.com/domains. No domain? Use SendGrid below instead.
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_ADDRESS=Helping Hands <onboarding@resend.dev>

# SendGrid (https://sendgrid.com) — free tier, HTTPS API. Use this if you
# don't have a domain to verify: SendGrid's "Single Sender Verification"
# (Settings -> Sender Authentication in their dashboard) verifies just one
# email address you already own — click a confirmation link, no DNS needed —
# and then that address can send to ANY recipient, unlike Resend's sandbox sender.
# To activate: set EMAIL_PROVIDER=sendgrid above instead of "resend".
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_ADDRESS=your-verified-address@gmail.com
SENDGRID_FROM_NAME=Helping Hands

# Brevo (https://brevo.com, formerly Sendinblue) — same single-sender model
# as SendGrid (Senders, Domains & Dedicated IPs -> Senders in their
# dashboard). Use this if SendGrid's own signup process is the blocker.
# To activate: set EMAIL_PROVIDER=brevo above instead of "resend".
BREVO_API_KEY=xkeysib-your_api_key_here
BREVO_FROM_ADDRESS=your-verified-address@gmail.com
BREVO_FROM_NAME=Helping Hands

# SMTP settings — only read when EMAIL_PROVIDER=smtp (self-hosted/VPS only;
# will NOT work on Render/Railway/most PaaS free tiers, see above).
# For Gmail: use an App Password (not your normal password) — https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-address@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=no-reply@helpinghands.local

# Must be your actual deployed frontend URL — used to build the links inside
# verification/reset emails. Wrong value here = broken email links, not an error.
FRONTEND_URL=https://your-app.vercel.app
